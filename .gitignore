# Thư mục chứa các gói thư viện (Rất nặng, Vercel sẽ tự cài lại)
node_modules/

# Thư mục build của Next.js (Được tạo ra khi chạy npm run build)
.next/
out/

# Các file môi trường (Chứa API keys, mật khẩu - TUYỆT ĐỐI không đẩy lên GitHub)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# File log và debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Thư mục của hệ điều hành (Rác hệ thống)
.DS_Store
Thumbs.db

# (Tùy chọn) Nếu bạn dùng VS Code, có thể bỏ qua thư mục cấu hình riêng
.vscode/