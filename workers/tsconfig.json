{
  "compilerOptions": {
    "target": "es2020",
    "lib": ["es2020"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "es2022",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,

    // Fix hình 2: types riêng cho Workers runtime
    // KVNamespace, R2Bucket, ExecutionContext, ScheduledEvent
    // đều được khai báo trong package này
    "types": ["@cloudflare/workers-types"]
  },
  "include": ["./*.ts"]
}