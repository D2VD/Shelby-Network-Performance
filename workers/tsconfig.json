{
  "compilerOptions": {
    "target":           "es2020",
    "lib":              ["es2020"],
    "allowJs":          false,
    "skipLibCheck":     true,
    "strict":           true,
    "noEmit":           true,
    "esModuleInterop":  true,
    "module":           "es2022",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules":  true,

    "types": [
      "@cloudflare/workers-types",
      "@types/node"
    ]
  },
  "include": ["./*.ts"]
}
